# =========================================================================
# Frontend (Vite) — these get bundled into the browser. Use anon-safe values.
# =========================================================================

# Supabase project URL and anon key — required.
# Found in Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry DSN for browser error reporting — optional.
# If unset, errors are only logged to console. If set, also add
# `@sentry/browser` to package.json dependencies for it to take effect.
# VITE_SENTRY_DSN=https://example@sentry.io/12345

# =========================================================================
# Edge functions — set these in Supabase dashboard → Project → Edge
# Functions → Secrets. They are NOT read from .env locally; this file is
# documentation only.
# =========================================================================

# --- Stripe (subscription billing) ---
# Required for /stripe-checkout and /stripe-webhook.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (transactional + campaign email) ---
# Required for /send-email, /send-email-campaign, /send-invoice-email.
# RESEND_API_KEY=re_...
# RESEND_WEBHOOK_SECRET=...   # Svix signing secret for bounce/complaint webhook

# --- Anthropic Claude (document OCR / accounting scan) ---
# Required for /scan-document, /scan-fleet-document.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Apple Push Notifications (driver iOS app) ---
# All four required together for /send-apns-notification.
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\nMI...\n-----END PRIVATE KEY-----"
# APNS_KEY_ID=ABCDEFGHIJ
# APNS_TEAM_ID=TEAMID12AB
# APNS_BUNDLE_ID=com.example.mmlogistic

# --- Firebase Cloud Messaging (driver Android app) ---
# Service account JSON, single line, for /send-fcm-notification.
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# --- Web Push (VAPID) for browser notifications ---
# Generate with `npx web-push generate-vapid-keys`.
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:info@mm-logistic.eu

# --- Setup / bootstrap token ---
# Required by /create-super-admin, /seed-demo-users,
# /create-demo-accountant, /init-push-config. When unset, those
# endpoints return 503. Use a long random string and rotate after
# bootstrap.
# SETUP_TOKEN=replace-with-long-random-string

# --- CORS allowlist for push endpoint ---
# Comma-separated origins. Leave unset for "*" (wildcard).
# ALLOWED_ORIGINS=https://app.mm-logistic.eu,https://staging.mm-logistic.eu

# --- Supabase platform-provided ---
# These are injected automatically by Supabase Edge into every
# function's runtime. Do NOT set them yourself.
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
